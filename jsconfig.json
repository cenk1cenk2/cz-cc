{
  "compilerOptions": {
    "target": "es2021",
    "lib": ["es2021"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*.js", "tsdown.config.mts"],
  "exclude": ["dist", "node_modules"]
}
